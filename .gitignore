# =============================================================================
.env
.env.local
.env.*.local
.env.backup
*.key
*.pem
*.p12
secrets/
credentials/

# Private keys (CRITICAL)
*private_key*
*_key.json
keystore/

# API keys
api_keys.txt
*.apikey

