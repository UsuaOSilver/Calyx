# =============================================================================
# Data & Models
# =============================================================================

# Large data files
data/raw/*.csv
data/raw/*.json
data/processed/*.pkl
data/datasets/*.h5
data/datasets/*.hdf5

# Model checkpoints
models/checkpoints/*.pt
models/checkpoints/*.pth
models/checkpoints/*.ckpt
models/checkpoints/*.h5

# Training logs
logs/
*.log
wandb/
tensorboard/

# ChromaDB vector database
chroma_db/
*.chroma

