# =============================================================================
# Project Specific
# =============================================================================

# Audit reports (too large for git)
data/collectors/raw/*.pdf
data/collectors/raw/*.html

# Processed datasets (regenerate from raw)
data/datasets/processed/

# Model training outputs
models/training_logs/
models/experiments/

# API response cache
.cache/
*.cache

# Demo data (can be large)
data/samples/*.json
!data/samples/bybit_attack.json

# Temporary upload files
uploads/
temp/

# Claude Code local config
.claude/

# Large generated datasets (regenerate via collectors + train pipeline)
data/datasets/bytecode/
data/datasets/bytecode_merged/
data/datasets/real_bytecode/
