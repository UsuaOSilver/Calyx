# Calyx — Environment Configuration
# Copy to .env and fill in values

# Required: Etherscan API key (free at etherscan.io)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# LLM Audit Agent (Stage 8) — only ONE key needed
# Anthropic Claude (best results)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini Flash (free tier — recommended for hackathon)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq Llama (free tier — fastest)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI GPT-4o (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Fork-EVM exploit validation (Stage 7) — optional
# Get free key at: https://dashboard.alchemy.com/
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Override LLM provider (auto-detected if not set)
# Options: anthropic, gemini, groq, openai
# AUDIT_PROVIDER=gemini

# Override model
# AUDIT_MODEL=gemini-2.0-flash
