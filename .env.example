# ── Required ──────────────────────────────────────────────────────────────────
# Bytecode fetch + transaction history (from etherscan.io → API Keys)
ETHERSCAN_API_KEY=

# ── AI Audit Agent (Stage 8) — pick any one ───────────────────────────────────
# Only one key is needed. Priority: Anthropic > Gemini > Groq > OpenAI
# Override selection with AUDIT_PROVIDER=groq (or gemini / anthropic / openai)

# Free tier at aistudio.google.com — 15 req/min daily quota
GEMINI_API_KEY=

# Free tier at console.groq.com — generous limits, llama-3.3-70b-versatile
GROQ_API_KEY=

# Paid — best output quality
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Stage 7: fork-EVM exploit validation (requires Anvil: https://getfoundry.sh)
# Alchemy free plan works: https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ETHEREUM_RPC_URL=

# Mempool monitor (scripts/monitor.py) — Alchemy WebSocket endpoint
MEMPOOL_WS_URL=
