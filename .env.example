# ── Required ──────────────────────────────────────────────────────────────────
# Etherscan V2 unified API key — covers ETH, BSC, Polygon, Arbitrum, Optimism,
# Base, and 55+ other EVM chains with a single key via the chainid parameter.
# Get free at etherscan.io → API Keys (one key, all chains)
ETHERSCAN_API_KEY=

# ── Optional: chain-specific keys (override ETHERSCAN_API_KEY per chain) ──────
# Only needed if you want to use a separate account for rate limit isolation.
# Without these, ETHERSCAN_API_KEY handles all chains automatically.
# BSCSCAN_API_KEY=
# POLYGONSCAN_API_KEY=
# ARBISCAN_API_KEY=
# OPTIMISM_API_KEY=

# ── AI Audit Agent (Stage 8) — pick any one ───────────────────────────────────
# Only one key is needed. Priority: Anthropic > Gemini > Groq > OpenAI
# Override selection with AUDIT_PROVIDER=groq (or gemini / anthropic / openai)

# Free tier at aistudio.google.com — 15 req/min daily quota
GEMINI_API_KEY=

# Free tier at console.groq.com — generous limits, llama-3.3-70b-versatile
GROQ_API_KEY=

# Paid — best output quality
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────
# Stage 7: fork-EVM exploit validation (requires Anvil: https://getfoundry.sh)
# Alchemy free plan works: https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
ETHEREUM_RPC_URL=

# Mempool monitor (scripts/monitor.py) — Alchemy WebSocket endpoint
MEMPOOL_WS_URL=
# Minimum ETH value to process (0 = all contract calls)
MEMPOOL_MIN_VALUE_ETH=0.0
# Set to "false" to disable deep bytecode pipeline (calldata-only mode)
MEMPOOL_PIPELINE=true

# ── Training data collection (scripts/weekly_data_sync.py) ───────────────────
# Solodit — free account at solodit.cyfrin.io → Settings → API Key
# Used to pull HIGH/CRITICAL audit findings → resolve to contract addresses via DefiLlama
SOLODIT_API_KEY=

# Forta Network — free at forta.org (improves alert rate limits)
FORTA_API_KEY=

# Dune Analytics — free at dune.com (500 credits/month on free tier)
# Used for ETH drain + BSC drain + flash loan pattern queries
DUNE_API_KEY=

# GoPlus Security — no key required for public tier (optional key lifts rate limits)
# Used to label honeypot/rugpull token contracts on ETH + BSC
# GOPLUS_API_KEY=

# Path to local DeFiHackLabs clone (default: /opt/DeFiHackLabs)
# git clone https://github.com/SunWeb3Sec/DeFiHackLabs.git /opt/DeFiHackLabs
DEFI_HACK_LABS_DIR=/opt/DeFiHackLabs
