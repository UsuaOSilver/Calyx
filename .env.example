# Calyx — Environment Configuration
# Copy to .env and fill in values

# Required: Etherscan API key (free at etherscan.io)
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# LLM Audit Agent (Stage 8) — only ONE key needed
# Anthropic Claude (best results)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini Flash (free tier — recommended for hackathon)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq Llama (free tier — fastest)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI GPT-4o (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Fork-EVM exploit validation (Stage 7) — optional
# Get free key at: https://dashboard.alchemy.com/
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Override LLM provider (auto-detected if not set)
# Options: anthropic, gemini, groq, openai
# AUDIT_PROVIDER=gemini

# Override model
# AUDIT_MODEL=gemini-2.0-flash

# =============================================================================
# MEMPOOL MONITOR (scripts/monitor.py)
# =============================================================================

# WebSocket RPC URL -- required for live mempool monitoring
# Alchemy free tier (300M CU/month) works well for focused mode
MEMPOOL_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/your_alchemy_key_here

# Minimum transaction value to process (ETH, default 0 = all contract calls)
MEMPOOL_MIN_VALUE_ETH=0.0

# Set to "false" to disable deep bytecode pipeline (calldata-only mode)
MEMPOOL_PIPELINE=true
